# Copy to .env.local for development or .env.production on the Hostinger VPS.
MYSQL_HOST=your-hostinger-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=TeakwoodProduction
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password

# App URL used in links and deployment checks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required before enabling login sessions in production.
APP_SESSION_SECRET=change-this-to-a-long-random-string
AUTH_SESSION_HOURS=8

# Optional. Required only for "Update Available Stock" Tranzact action.
TRANZACT_LOGIN_URL=https://be.letstranzact.com/main/login/password-login/
TRANZACT_BASE_URL=https://be.letstranzact.com
TRANZACT_EMAIL=your_tranzact_email
TRANZACT_PASSWORD=your_tranzact_password
TRANZACT_MAX_RETRIES=5
TRANZACT_PAGE_DELAY_MS=1500
